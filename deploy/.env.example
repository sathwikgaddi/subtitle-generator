# Copy this file to deploy/.env and fill in real values.
# deploy/.env is gitignored; this example file is the only one committed.

# --- Postgres (local docker-compose) ---
POSTGRES_DB=subtitles
POSTGRES_USER=subtitles
POSTGRES_PASSWORD=changeme-local-dev-only

# --- ASP.NET Core Identity / JWT (Subtitles.Api) ---
# Any long random string for local dev; a real secret in deployed environments.
JWT_SIGNING_KEY=changeme-local-dev-only-please-use-a-long-random-string

# --- AI providers (Subtitles.Worker) ---
# See docs/Architecture.md §3 and the ILlmProvider/ISpeechToTextProvider
# config sections in appsettings.json for provider/model selection.
# The API key is the only secret; provider and model are non-secret config.
OPENAI_API_KEY=sk-changeme
